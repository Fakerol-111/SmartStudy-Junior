# ── Default DeepSeek (fallback for all components) ──
EXPO_PUBLIC_DEEPSEEK_API_KEY=
EXPO_PUBLIC_DEEPSEEK_BASE_URL=https://api.deepseek.com
EXPO_PUBLIC_DEEPSEEK_MODEL=deepseek-chat

# ── Default Flagship ──
EXPO_PUBLIC_FLAGSHIP_API_KEY=
EXPO_PUBLIC_FLAGSHIP_BASE_URL=https://api.deepseek.com
EXPO_PUBLIC_FLAGSHIP_MODEL=deepseek-chat

# ── Independent component configs ──
EXPO_PUBLIC_HANDLER_API_KEY=
EXPO_PUBLIC_HANDLER_BASE_URL=https://api.deepseek.com
EXPO_PUBLIC_HANDLER_MODEL=deepseek-chat
EXPO_PUBLIC_HANDLER_FLAGSHIP_API_KEY=
EXPO_PUBLIC_HANDLER_FLAGSHIP_BASE_URL=https://api.deepseek.com
EXPO_PUBLIC_HANDLER_FLAGSHIP_MODEL=deepseek-v4-flash

EXPO_PUBLIC_ROUTER_API_KEY=
EXPO_PUBLIC_ROUTER_BASE_URL=https://api.deepseek.com
EXPO_PUBLIC_ROUTER_MODEL=deepseek-chat

EXPO_PUBLIC_REVIEWER_API_KEY=
EXPO_PUBLIC_REVIEWER_BASE_URL=https://api.deepseek.com
EXPO_PUBLIC_REVIEWER_MODEL=deepseek-chat
EXPO_PUBLIC_REVIEWER_FLAGSHIP_API_KEY=
EXPO_PUBLIC_REVIEWER_FLAGSHIP_BASE_URL=https://api.deepseek.com
EXPO_PUBLIC_REVIEWER_FLAGSHIP_MODEL=deepseek-v4-flash

# ── API Usage Telemetry ──
EXPO_PUBLIC_TELEMETRY_ENDPOINT=https://smartstudy-usage.你的子域名.workers.dev/api/usage

# ── OCR / Multimodal ──
EXPO_PUBLIC_OCR_API_KEY=
EXPO_PUBLIC_OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EXPO_PUBLIC_OCR_MODEL=qwen3.6-plus
